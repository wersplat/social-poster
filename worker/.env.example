# Supabase (service role — keep secret; never commit .env)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# X app credentials
X_API_KEY=
X_API_SECRET=

# Default X user tokens (fallback when per-league tokens are not in webhook_config)
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# HTTP admin (same process as poller on Railway)
PORT=3000
ADMIN_SECRET=

# X 3-legged OAuth (Policies → Link X). Must match callback URL in your X app settings.
# Default if unset: https://<your-host>/api/x/oauth/callback (derive from request Origin).
# X_OAUTH_CALLBACK_URL=https://your-service.up.railway.app/api/x/oauth/callback

# Cloudflare R2 (optional — game cards + AI backgrounds). Same layout as lba-social worker.
# API token: Object Read & Write on the bucket (403 = wrong scope).
# Use EITHER full endpoint OR account id (not required to set both):
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# First path segment = bucket name; optional extra segments = object key prefix (lba-social style).
# Examples: my-bucket  OR  my-bucket/graphics/lba
R2_BUCKET=
# Public origin for objects, e.g. https://pub-xxxxx.r2.dev (no trailing slash)
R2_PUBLIC_BASE_URL=

# Planning job (POST /api/jobs/plan) — league UUID from leagues_info
LEAGUE_ID=

# Default style pack for planned posts: regular | playoffs | rivalry | sponsor_safe | regular_season_launch | stage_combine_playground
PLAN_DEFAULT_STYLE_PACK=regular

# Power rankings schedule (0 = Sunday)
POWER_RANKINGS_DAY=0
POWER_RANKINGS_HOUR=18

# AI image generation (OpenAI or Gemini Imagen)
AI_IMAGE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_SIZE=
OPENAI_IMAGE_QUALITY=

GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_ASPECT_RATIO=

# Optional: replace default LBA color copy in prompts (plain text)
AI_IMAGE_BRAND_RULES=
