# Supabase (service role — keep secret; never commit .env)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# X app credentials
X_API_KEY=
X_API_SECRET=

# Default X user tokens (fallback when per-league tokens are not in webhook_config)
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# HTTP admin (same process as poller on Railway)
PORT=3000
ADMIN_SECRET=

# Cloudflare R2 (optional — game cards for verified_game posts without bg_image_url)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
