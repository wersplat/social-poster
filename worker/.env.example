# --- Supabase (service role — keep secret; never commit .env) ---
SUPABASE_URL=
# Either key name works (unified worker accepts both)
SUPABASE_SERVICE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- League scope (planning + Instagram queries) ---
LEAGUE_ID=

# --- HTTP admin + X poller ---
PORT=3000
ADMIN_SECRET=

# --- X app credentials ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# X 3-legged OAuth (Policies → Link X). Must match callback URL in X app settings.
# X_OAUTH_CALLBACK_URL=https://your-service.up.railway.app/api/x/oauth/callback

# --- Feature flags (default: all enabled except where noted) ---
# ENABLE_X_POLLER=false
# ENABLE_X_PLANNING=false
# ENABLE_INSTAGRAM_JOBS=false
# ENABLE_INSTAGRAM_PLANNING=false
# HTTP_ENABLED=false
# INSTAGRAM_PIPELINE_INTERVAL_MS=300000

# One-shot job mode (no HTTP server): HTTP_ENABLED=false and set JOB
# JOB=plan|render|publish|renderVideo|publishVideo|all

# --- Cloudflare R2 (game cards, AI backgrounds, Instagram assets) ---
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- Planning defaults ---
PLAN_DEFAULT_STYLE_PACK=regular
POWER_RANKINGS_DAY=0
POWER_RANKINGS_HOUR=18

# --- AI image (X card backgrounds; shared with Instagram worker path) ---
AI_IMAGE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_SIZE=
OPENAI_IMAGE_QUALITY=
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_ASPECT_RATIO=
AI_IMAGE_BRAND_RULES=

# --- Meta / Instagram ---
META_ACCESS_TOKEN=
IG_USER_ID=
GRAPH_API_VERSION=v24.0

# --- AI captions (Instagram) ---
# AI_CAPTION_PROVIDER=openai
# AI_IMAGE_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.6
OPENAI_MAX_OUTPUT_TOKENS=500
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1536
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Boxscore branding (optional) ---
# LBA_LOGO_URL=https://logo.proamrank.gg/lba.avif
# BOXSCORE_HEADER_ENABLED=true
# BOXSCORE_HEADER_TEXT=LBA VERIFIED BOX SCORE

# --- Video (optional) ---
# FFMPEG_PATH=ffmpeg
# VIDEO_FPS=30
